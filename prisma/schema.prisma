generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Card {
  id       String     @id
  name     String
  imageUrl String?
  faces    CardFace[]
  imageUrl String?
  decks    Branch[]
  Change   Change[] // Changes related to this card in the context of branches and commits
}

model CardFace {
  cardId   String
  name     String
  imageUrl String?
  card     Card    @relation(fields: [cardId], references: [id], onDelete: Cascade)
  @@id([cardId, name])
}

model User {
  email     String    @id @unique
  username  String    @unique
  name      String
  password  String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  decks     Deck[] // A user can have multiple decks
  sessions  Session[] // A user can have multiple sessions

  @@index([username])
}

model Session {
  id        String   @id
  user      User     @relation(fields: [userEmail], references: [email])
  userEmail String
  createdAt DateTime @default(now())
  lastSeen  DateTime @default(now())
  expires   DateTime
}

model Deck {
  id          String   @id
  name        String
  userEmail   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  description String?
  user        User     @relation(fields: [userEmail], references: [email], onDelete: Cascade) // A deck belongs to a user
  branches Branch[] // A deck can have multiple branches for version control
}

model Branch {
  id           String   @id
  name         String   @default("main")
  deckId       String
  deck         Deck     @relation(fields: [deckId], references: [id], onDelete: Cascade) // A branch belongs to a deck
  cards        Card[] // each branch has a decklist
  commits      Commit[] // A branch can have multiple commits
  headCommitId String // A branch has a head commit for the latest state
}

model Commit {
  id           String   @unique @id @db.Char(10)
  description  String
  createdAt    DateTime @default(now())
  branchId     String
  changes      Change[]
  headBranchOf Branch?  @relation(name: "HEAD")
  branch       Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  snapshot     SnapShot?
}

model SnapShot {
  id String @db.Char(10) @id
  commit Commit @relation(fields: [commitID], references: [id])
  commitID String @unique
  card Card[] @relation("CardToSnapshot")
}

model Change {
  action         String
  commitId       String
  cardId         String
  card           Card   @relation(fields: [cardId], references: [id], onDelete: Cascade)
  commit         Commit @relation(fields: [commitId], references: [id], onDelete: Cascade)

  @@id([action, cardId, commitId])
}
