generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Card {
  id        String     @id
  name      String
  imageUrl  String?
  faces     CardFace[]
  mainDecks Decklist[] @relation("CardToDecklistMain")
  sideBoards Decklist[] @relation("CardToDecklistSide")
  Change    Change[]
}

model CardFace {
  cardId   String
  name     String
  imageUrl String?
  card     Card    @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@id([cardId, name])
}

model User {
  email     String    @id @unique
  username  String    @unique
  name      String
  password  String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  decks     Deck[] // A user can have multiple decks
  sessions  Session[] // A user can have multiple sessions

  @@index([username])
}

model Session {
  id        String   @id
  user      User     @relation(fields: [userEmail], references: [email])
  userEmail String
  createdAt DateTime @default(now())
  lastSeen  DateTime @default(now())
  expires   DateTime
}

model Deck {
  id          String   @id
  name        String
  userEmail   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  description String?
  user        User     @relation(fields: [userEmail], references: [email], onDelete: Cascade) // A deck belongs to a user
  branches    Branch[] // A deck can have multiple branches for version control
}

model Decklist {
  id       String    @id
  mainDeck Card[]    @relation("CardToDecklistMain")
  sideBoard Card[]   @relation("CardToDecklistSide")
  branch   Branch?
  snapShot SnapShot?
}

model Branch {
  id           String   @id
  name         String   @default("main")
  deckId       String
  deck         Deck     @relation(fields: [deckId], references: [id], onDelete: Cascade) // A branch belongs to a deck
  decklistId   String   @unique
  decklist     Decklist @relation(fields: [decklistId], references: [id])
  commits      Commit[]
  headCommitId String?  @unique @db.Char(10)
  headCommit   Commit?  @relation(name: "HEAD", fields: [headCommitId], references: [id])
}

model Commit {
  id           String    @id @unique @db.Char(10)
  description  String
  createdAt    DateTime  @default(now())
  branchId     String
  changes      Change[]
  headBranchOf Branch?   @relation(name: "HEAD")
  branch       Branch    @relation(fields: [branchId], references: [id], onDelete: Cascade)
  snapshot     SnapShot?
}

model SnapShot {
  id         String   @id @db.Char(10)
  commit     Commit   @relation(fields: [commitID], references: [id])
  commitID   String   @unique
  decklistId String   @unique
  decklist   Decklist @relation(fields: [decklistId], references: [id])
}

model Change {
  action   Action
  board    Board
  commitId String
  cardId   String
  card     Card   @relation(fields: [cardId], references: [id], onDelete: Cascade)
  commit   Commit @relation(fields: [commitId], references: [id], onDelete: Cascade)

  @@id([action, cardId, commitId])
}

enum Action {
  ADD
  REMOVE
}

enum Board {
  MAIN
  SIDE
  COMMANDER
  CONSIDERING
}
